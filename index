    question: '¿Cuántas Copas del Mundo acumula Argentina tras ganar Qatar 2022?',
    options: ['2', '3', '4', '5'],
    correct: 1   // 3 (1978, 1986, 2022)
},

// ── QUIZ · 2022 ───────────────────────────────────────────
{
    type: 'quiz',
    icon: '🧠',
    question: '¿Quién marcó un hat-trick en la final de Qatar 2022?',
    options: ['Lionel Messi', 'Olivier Giroud', 'Kylian Mbappé', 'Ángel Di María'],
    correct: 2   // Mbappé (minutos 80', 81' y 118')
}


];


/* =================================================================
   MOTOR
================================================================= */
const CIRC = 2 * Math.PI * 50; // radio 50 del SVG del timer

let idx = 0;
let timerID = null;

// --- Utilidad: cambiar vista ---
function show(id) {
    $('.view').removeClass('active');
    $('#' + id).addClass('active');
}

// --- Render carta actual ---
function renderCard() {
    if (idx >= CARDS.length) { show('view-end'); return; }

    killTimer();

    const card  = CARDS[idx];
    const total = CARDS.length;

    // Barra de progreso y contador
    $('#progress-bar').css('width', (idx / total * 100) + '%');
    $('#counter').text((idx + 1) + ' / ' + total);

    // Construir HTML según tipo
    let html = '';
    if (card.type === 'simple') html = tplSimple(card);
    if (card.type === 'timer')  html = tplTimer(card);
    if (card.type === 'quiz')   html = tplQuiz(card);

    $('#card-wrap').html(html);
    $('.card-n').addClass('anim-in');

    // Activar lógica específica
    if (card.type === 'timer') initTimer(card);
    if (card.type === 'quiz')  initQuiz(card);
}

// --- Pasar a la siguiente carta ---
function advance(direction) {
    killTimer();
    const cls = (direction === 'left') ? 'anim-out-l' : 'anim-out-r';
    $('.card-n').removeClass('anim-in').addClass(cls);
    setTimeout(() => { idx++; renderCard(); }, 290);
}

function killTimer() {
    if (timerID) { clearInterval(timerID); timerID = null; }
}

// --- Fisher-Yates shuffle (mezcla el arreglo en su lugar) ---
function shuffle(arr) {
    for (let i = arr.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [arr[i], arr[j]] = [arr[j], arr[i]];
    }
}


/* =================================================================
   TEMPLATE: SIMPLE
================================================================= */
function tplSimple(c) {
    return `
    <div class="card-n">
        <span class="card-tag">Reto</span>
        <div class="card-icon">${c.icon}</div>
        <p class="card-text">${c.text}</p>
        <div class="action-row">
            <button class="btn-fail js-fail">✗ Fallé</button>
            <button class="btn-ok js-ok">✓ Lo hice</button>
        </div>
    </div>`;
}


/* =================================================================
   TEMPLATE: TIMER
================================================================= */
function tplTimer(c) {
    return `
    <div class="card-n">
        <span class="card-tag">Cronómetro</span>
        <div class="card-icon">${c.icon}</div>
        <p class="card-text">${c.text}</p>

        <div class="timer-wrap">
            <svg class="timer-svg" viewBox="0 0 110 110">
                <circle class="timer-track" cx="55" cy="55" r="50"/>
                <circle class="timer-arc"   cx="55" cy="55" r="50"
                    id="t-arc"
                    stroke-dasharray="${CIRC}"
                    stroke-dashoffset="0"/>
            </svg>
            <div class="timer-num" id="t-num">${c.duration}</div>
        </div>

        <button class="btn-start-timer" id="t-btn">▶ INICIAR</button>

        <div class="action-row" id="t-actions" style="display:none">
            <button class="btn-fail js-fail">✗ No lo logré</button>
            <button class="btn-ok   js-ok">✓ ¡Salvado!</button>
        </div>
    </div>`;
}

function initTimer(c) {
    let left = c.duration;

    $('#t-btn').one('click', function() {
        $(this).attr('disabled', true).text('⏳ CORRIENDO…');

        timerID = setInterval(function() {
            left--;

            // Arco SVG
            const offset = CIRC * (1 - left / c.duration);
            $('#t-arc').css('stroke-dashoffset', offset);
            $('#t-num').text(left);

            // Cambio de color en los últimos 5 s
            if (left <= 5) {
                $('#t-arc').css({ stroke: 'var(--red)', filter: 'drop-shadow(0 0 6px var(--red))' });
                $('#t-num').css({ color: 'var(--red)', 'text-shadow': '0 0 12px var(--red)' });
            }

            if (left <= 0) {
                killTimer();
                $('#t-num').text('⏰');
                $('#t-actions').slideDown(280);
            }
        }, 1000);
    });
}


/* =================================================================
   TEMPLATE: QUIZ
================================================================= */
function tplQuiz(c) {
    const opts = c.options.map((o, i) =>
        `<div class="quiz-opt" data-i="${i}">${o}</div>`
    ).join('');

    return `
    <div class="card-n">
        <span class="card-tag">Trivia</span>
        <div class="card-icon">${c.icon}</div>
        <p class="card-text">${c.question}</p>
        <div class="quiz-grid">${opts}</div>
        <div class="quiz-verdict" id="q-verdict"></div>
        <div class="action-row" id="q-actions" style="display:none">
            <button class="btn-fail js-fail">✗ Fallé</button>
            <button class="btn-ok   js-ok">✓ Acerté</button>
        </div>
    </div>`;
}

function initQuiz(c) {
    let done = false;

    $(document).off('click.quiz').on('click.quiz', '.quiz-opt', function() {
        if (done) return;
        done = true;

        const chosen  = parseInt($(this).data('i'));
        const correct = c.correct;

        // Marcar todas las opciones
        $('.quiz-opt').each(function(i) {
            if (i === correct) {
                $(this).addClass('--correct');
            } else if (i === chosen) {
                $(this).addClass('--wrong');
            } else {
                $(this).addClass('--dim');
            }
        });

        // Veredicto
        const $v = $('#q-verdict');
        if (chosen === correct) {
            $v.text('¡Correcto! 🎉').addClass('--correct').show();
        } else {
            $v.text('¡Incorrecto! Bebe 🍺').addClass('--wrong').show();
        }

        setTimeout(() => $('#q-actions').slideDown(280), 500);
    });
}


/* =================================================================
   DELEGACIÓN GLOBAL DE BOTONES DE ACCIÓN
   (funciona para cualquier tipo de carta)
================================================================= */
$(document).on('click', '.js-ok',   () => advance('right'));
$(document).on('click', '.js-fail', () => advance('left'));


/* =================================================================
   NAVEGACIÓN ENTRE VISTAS
================================================================= */
$('#btn-start').on('click', function() {
    idx = 0;
    shuffle(CARDS);
    show('view-game');
    renderCard();
});

$('#btn-restart').on('click', function() {
    idx = 0;
    shuffle(CARDS);
    show('view-game');
    renderCard();
});

$('#btn-home').on('click', function() {
    killTimer();
    show('view-home');
});

</script>
</body>
</html>
