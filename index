    </div>
    <div class="progress-rail">
        <div class="progress-bar" id="progress-bar"></div>
    </div>
    <div id="card-wrap"></div>
</div>


<!-- =============================================================
     VIEW: END
============================================================== -->
<div id="view-end" class="view">
    <div class="end-icon">🍺</div>
    <h2 class="end-title">¡JUEGO TERMINADO!</h2>
