<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
    <title>⚽ FÚTSHOT</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@400;500;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>

        /* ================================================
           TOKENS
        ================================================ */
        :root {
            --bg:       #000000;
            --cyan:     #00ffff;
            --magenta:  #ff00ff;
            --green:    #00ff41;
            --red:      #ff3131;
            --yellow:   #ffff00;
            --card-bg:  #080808;
            --font-d:   'Orbitron', sans-serif;
            --font-b:   'Rajdhani', sans-serif;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: var(--bg);
            color: #fff;
            font-family: var(--font-b);
            min-height: 100dvh;
            overflow-x: hidden;
            -webkit-tap-highlight-color: transparent;
        }

        /* Scanline overlay – the signature aesthetic risk */
        body::after {
            content: '';
            position: fixed;
            inset: 0;
            background: repeating-linear-gradient(
                to bottom,
                transparent 0px,
                transparent 3px,
                rgba(0,0,0,0.07) 3px,
                rgba(0,0,0,0.07) 4px
            );
            pointer-events: none;
            z-index: 9999;
        }

        /* ================================================
           VIEW SYSTEM
        ================================================ */
        .view {
            display: none;
            min-height: 100dvh;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 1.5rem 1rem;
        }
        .view.active { display: flex; }


        /* ================================================
           HOME
        ================================================ */
        #view-home {
            background: radial-gradient(ellipse at 50% 30%, #001f1f 0%, #000 65%);
            text-align: center;
            gap: 0;
        }

        .home-logo {
            font-size: 4.5rem;
            line-height: 1;
            filter: drop-shadow(0 0 18px var(--cyan));
            animation: bob 3s ease-in-out infinite;
        }

        .home-title {
            font-family: var(--font-d);
            font-size: clamp(2.2rem, 10vw, 3rem);
            font-weight: 900;
            color: var(--cyan);
            text-shadow:
                0 0 8px  var(--cyan),
                0 0 24px var(--cyan),
                0 0 60px var(--cyan);
            letter-spacing: 0.12em;
            margin-top: 0.6rem;
            animation: flicker 5s infinite;
        }

        .home-sub {
            font-family: var(--font-d);
            font-size: 0.7rem;
            letter-spacing: 0.3em;
            color: var(--magenta);
            text-shadow: 0 0 8px var(--magenta);
            text-transform: uppercase;
            margin-top: 0.25rem;
        }

        .home-divider {
            width: 70px;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--cyan), transparent);
            box-shadow: 0 0 8px var(--cyan);
            margin: 1.5rem auto;
        }

        .home-desc {
            font-size: 1rem;
            color: #888;
            max-width: 290px;
            line-height: 1.65;
            margin-bottom: 2rem;
        }


        /* ================================================
           SHARED BUTTON STYLES
        ================================================ */
        .btn-neon {
            font-family: var(--font-d);
            font-size: 0.85rem;
            font-weight: 700;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            padding: 0.9rem 2.2rem;
            border: 2px solid var(--cyan);
            color: var(--cyan);
            background: transparent;
            border-radius: 5px;
            cursor: pointer;
            box-shadow: 0 0 10px rgba(0,255,255,0.4), inset 0 0 0 transparent;
            text-shadow: 0 0 8px var(--cyan);
            transition: all 0.18s ease;
        }
        .btn-neon:active {
            background: var(--cyan);
            color: #000;
            box-shadow: 0 0 25px var(--cyan), 0 0 50px rgba(0,255,255,0.4);
            text-shadow: none;
        }

        .btn-neon.--mg {
            border-color: var(--magenta);
            color: var(--magenta);
            text-shadow: 0 0 8px var(--magenta);
            box-shadow: 0 0 10px rgba(255,0,255,0.4);
        }
        .btn-neon.--mg:active {
            background: var(--magenta);
            color: #000;
            box-shadow: 0 0 25px var(--magenta);
            text-shadow: none;
        }


        /* ================================================
           GAME VIEW
        ================================================ */
        #view-game {
            background: radial-gradient(ellipse at 50% 0%, #001f1f 0%, #000 55%);
            justify-content: flex-start;
            padding-top: 1rem;
        }

        .game-bar {
            width: 100%;
            max-width: 390px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.6rem;
        }

        .game-logo {
            font-family: var(--font-d);
            font-size: 0.85rem;
            color: var(--cyan);
            text-shadow: 0 0 6px var(--cyan);
            letter-spacing: 0.1em;
        }

        .counter {
            font-family: var(--font-d);
            font-size: 0.8rem;
            color: var(--magenta);
            text-shadow: 0 0 6px var(--magenta);
        }

        .progress-rail {
            width: 100%;
            max-width: 390px;
            height: 3px;
            background: #111;
            border-radius: 2px;
            overflow: hidden;
            margin-bottom: 1.4rem;
        }

        .progress-bar {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, var(--cyan), var(--magenta));
            box-shadow: 0 0 8px var(--cyan);
            border-radius: 2px;
            transition: width 0.4s ease;
        }

        /* Card wrapper keeps a fixed viewport-aware height */
        #card-wrap {
            width: 100%;
            max-width: 390px;
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* ---- THE CARD ---- */
        .card-n {
            width: 100%;
            background: var(--card-bg);
            border: 1.5px solid var(--cyan);
            border-radius: 18px;
            box-shadow:
                0 0 18px rgba(0,255,255,0.25),
                0 0 50px rgba(0,255,255,0.08);
            padding: 2rem 1.4rem 1.6rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
            /* entry animation applied by JS */
        }

        .card-tag {
            position: absolute;
            top: 1rem;
            right: 1.1rem;
            font-family: var(--font-d);
            font-size: 0.55rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--magenta);
            text-shadow: 0 0 6px var(--magenta);
        }

        .card-icon {
            font-size: 2.6rem;
            margin-bottom: 0.9rem;
            filter: drop-shadow(0 0 10px var(--cyan));
        }

        .card-text {
            font-size: 1.25rem;
            font-weight: 600;
            text-align: center;
            line-height: 1.55;
            color: #f0f0f0;
        }

        /* Action row */
        .action-row {
            display: flex;
            gap: 0.9rem;
            width: 100%;
            margin-top: 1.8rem;
        }

        .btn-fail {
            flex: 1;
            padding: 0.8rem 0.4rem;
            border: 2px solid var(--red);
            color: var(--red);
            background: transparent;
            border-radius: 8px;
            font-family: var(--font-d);
            font-size: 0.65rem;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            cursor: pointer;
            text-shadow: 0 0 6px var(--red);
            box-shadow: 0 0 8px rgba(255,49,49,0.3);
            transition: all 0.18s;
        }
        .btn-fail:active {
            background: var(--red);
            color: #000;
            box-shadow: 0 0 22px var(--red);
            text-shadow: none;
        }

        .btn-ok {
            flex: 1;
            padding: 0.8rem 0.4rem;
            border: 2px solid var(--green);
            color: var(--green);
            background: transparent;
            border-radius: 8px;
            font-family: var(--font-d);
            font-size: 0.65rem;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            cursor: pointer;
            text-shadow: 0 0 6px var(--green);
            box-shadow: 0 0 8px rgba(0,255,65,0.3);
            transition: all 0.18s;
        }
        .btn-ok:active {
            background: var(--green);
            color: #000;
            box-shadow: 0 0 22px var(--green);
            text-shadow: none;
        }


        /* ================================================
           TIMER TEMPLATE
        ================================================ */
        .timer-wrap {
            position: relative;
            width: 120px;
            height: 120px;
            margin: 1rem auto 0.3rem;
        }

        .timer-svg {
            width: 120px;
            height: 120px;
            transform: rotate(-90deg);
        }

        .timer-track { fill: none; stroke: #181818; stroke-width: 7; }

        .timer-arc {
            fill: none;
            stroke: var(--yellow);
            stroke-width: 7;
            stroke-linecap: round;
            filter: drop-shadow(0 0 5px var(--yellow));
            transition: stroke-dashoffset 1s linear, stroke 0.3s;
        }

        .timer-num {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--font-d);
            font-size: 2rem;
            font-weight: 900;
            color: var(--yellow);
            text-shadow: 0 0 12px var(--yellow), 0 0 24px var(--yellow);
            transition: color 0.3s, text-shadow 0.3s;
        }

        .btn-start-timer {
            margin-top: 0.6rem;
            padding: 0.55rem 1.6rem;
            border: 2px solid var(--yellow);
            color: var(--yellow);
            background: transparent;
            border-radius: 6px;
            font-family: var(--font-d);
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            cursor: pointer;
            text-shadow: 0 0 6px var(--yellow);
            box-shadow: 0 0 8px rgba(255,255,0,0.3);
            transition: all 0.18s;
        }
        .btn-start-timer:active {
            background: var(--yellow);
            color: #000;
        }
        .btn-start-timer:disabled {
            opacity: 0.4;
            pointer-events: none;
        }


        /* ================================================
           QUIZ TEMPLATE
        ================================================ */
        .quiz-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.7rem;
            width: 100%;
            margin-top: 1.4rem;
        }

        .quiz-opt {
            padding: 0.85rem 0.4rem;
            border: 1.5px solid #2a2a2a;
            color: #aaa;
            background: #0d0d0d;
            border-radius: 8px;
            font-family: var(--font-b);
            font-size: 1.05rem;
            font-weight: 600;
            text-align: center;
            cursor: pointer;
            transition: all 0.22s ease;
        }
        .quiz-opt:active { opacity: 0.7; }

        .quiz-opt.--correct {
            border-color: var(--green) !important;
            color: var(--green) !important;
            background: rgba(0,255,65,0.07) !important;
            box-shadow: 0 0 14px rgba(0,255,65,0.35) !important;
            text-shadow: 0 0 6px var(--green) !important;
        }
        .quiz-opt.--wrong {
            border-color: var(--red) !important;
            color: var(--red) !important;
            background: rgba(255,49,49,0.07) !important;
        }
        .quiz-opt.--dim { pointer-events: none; opacity: 0.45; }

        .quiz-verdict {
            margin-top: 0.9rem;
            font-family: var(--font-d);
            font-size: 0.8rem;
            letter-spacing: 0.12em;
            text-align: center;
            display: none;
        }
        .quiz-verdict.--correct { color: var(--green); text-shadow: 0 0 8px var(--green); }
        .quiz-verdict.--wrong   { color: var(--red);   text-shadow: 0 0 8px var(--red);   }


        /* ================================================
           END
        ================================================ */
        #view-end {
            background: radial-gradient(ellipse at 50% 40%, #1a0020 0%, #000 65%);
            text-align: center;
            gap: 0;
        }

        .end-icon {
            font-size: 4.5rem;
            filter: drop-shadow(0 0 20px var(--magenta));
            animation: bob 2s ease-in-out infinite;
        }

        .end-title {
            font-family: var(--font-d);
            font-size: clamp(1.5rem, 7vw, 2.2rem);
            font-weight: 900;
            color: var(--magenta);
            text-shadow: 0 0 10px var(--magenta), 0 0 30px var(--magenta);
            margin: 1rem 0 0.4rem;
        }

        .end-sub {
            color: #666;
            font-size: 1rem;
            margin-bottom: 2rem;
        }

        .end-btns { display: flex; flex-direction: column; gap: 1rem; }


        /* ================================================
           ANIMATIONS
        ================================================ */
        @keyframes bob {
            0%, 100% { transform: translateY(0); }
            50%       { transform: translateY(-8px); }
        }

        @keyframes flicker {
            0%,18%,20%,22%,55%,57%,100% {
                text-shadow: 0 0 8px var(--cyan), 0 0 24px var(--cyan), 0 0 60px var(--cyan);
            }
            19%,21%,56% { text-shadow: none; }
        }

        @keyframes card-in {
            from { opacity: 0; transform: translateY(36px) scale(0.97); }
            to   { opacity: 1; transform: translateY(0)    scale(1);    }
        }

        .anim-in  { animation: card-in 0.32s ease forwards; }

        .anim-out-l {
            animation: card-out-l 0.28s ease forwards;
        }
        .anim-out-r {
            animation: card-out-r 0.28s ease forwards;
        }

        @keyframes card-out-l {
            to { opacity: 0; transform: translateX(-110%) rotate(-8deg); }
        }
        @keyframes card-out-r {
            to { opacity: 0; transform: translateX(110%)  rotate(8deg);  }
        }

    </style>
</head>
